# =============================================================================
# Umbrella (parent) repo .gitignore
# =============================================================================

# Nested working repos — version-controlled independently by their own remotes.
# The parent (umbrella) repo must not track anything inside them.
/diploma-cloud-cyber-content/
/diploma-cloud-cyber-website/

# Personal, machine-local instructions — not synced across machines.
/CLAUDE.local.md

# Secrets — NEVER commit. The API key lives in .env; .env.example is the committed template.
.env
**/.env

# Per-skill virtualenvs + Python caches — machine-specific; only requirements.txt is committed.
**/.venv/
__pycache__/
