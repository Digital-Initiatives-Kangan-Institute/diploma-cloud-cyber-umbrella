# Example environment file. Copy to .env and fill in real values:
#   cp .env.example .env   then edit .env
#
# .env is encrypted with git-crypt (see .gitattributes); this template is NOT
# (it holds no secrets) so anyone cloning the repo knows which keys are needed.

# OpenRouter — multi-model image generation (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Optional fallback — OpenAI direct, for reference-image features not exposed via OpenRouter
# OPENAI_API_KEY=
