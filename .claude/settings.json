{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "//hooks": "SessionStart self-heal: point this machine's auto-memory at the repo's .claude/memory (idempotent; see skills/ensure-repo-memory). Windows/PowerShell.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/.claude/skills/ensure-repo-memory/ensure_repo_memory.ps1\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
